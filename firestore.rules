rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 1. Users
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
      
      function isValidUser(data) {
        return data.uid == request.auth.uid &&
               data.email is string &&
               data.displayName is string &&
               data.displayName.size() <= 100;
      }
    }

    // 2. Writing Entries
    match /writing/{entryId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidWriting(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      function isValidWriting(data) {
        return data.userId == request.auth.uid &&
               data.originalText is string && data.originalText.size() <= 10000 &&
               data.createdAt == request.time;
      }
    }

    // 3. Learning Tasks
    match /learning/{taskId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && incoming().userId == request.auth.uid && isValidTask(incoming());

      function isValidTask(data) {
        return data.userId == request.auth.uid &&
               data.topic is string && data.topic.size() <= 200 &&
               data.status in ['pending', 'completed', 'submitted'];
      }
    }

    // 4. Mood Logs
    match /moods/{logId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidMood(incoming());

      function isValidMood(data) {
        return data.userId == request.auth.uid &&
               data.mood is string && data.mood.size() <= 50 &&
               data.createdAt == request.time;
      }
    }

    // 5. Finance Transactions
    match /transactions/{transactionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && incoming().userId == request.auth.uid && isValidTransaction(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      function isValidTransaction(data) {
        return data.userId == request.auth.uid &&
               data.type in ['income', 'expense'] &&
               data.amount is number &&
               data.category is string && data.category.size() <= 50 &&
               data.createdAt == request.time;
      }
    }

    // 6. Budgets
    match /budgets/{budgetId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isVerified() && incoming().userId == request.auth.uid && isValidBudget(incoming());

      function isValidBudget(data) {
        return data.userId == request.auth.uid &&
               data.category is string &&
               data.limit is number &&
               data.month is string;
      }
    }

    // 7. Investments
    match /investments/{investmentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isVerified() && incoming().userId == request.auth.uid && isValidInvestment(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      function isValidInvestment(data) {
        return data.userId == request.auth.uid &&
               data.assetName is string &&
               data.amount is number &&
               data.type in ['stock', 'crypto', 'savings'];
      }
    }
  }
}
