{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "WritingEntry": {
      "title": "Writing Entry",
      "description": "Captured ideas, stories, and improved texts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "transcript": { "type": "string" },
        "originalText": { "type": "string" },
        "improvedText": { "type": "string" },
        "mood": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "originalText", "createdAt"]
    },
    "LearningTask": {
      "title": "Learning Task",
      "description": "Daily/weekly tasks generated by the AI mentor",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "topic": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["quiz", "project", "ppt"] },
        "status": { "type": "string", "enum": ["pending", "completed", "submitted"] },
        "score": { "type": "integer" },
        "feedback": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "topic", "description", "status", "createdAt"]
    },
    "MoodLog": {
      "title": "Mood Log",
      "description": "User's emotional state logs",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mood": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mood", "createdAt"]
    },
    "FinanceTransaction": {
      "title": "Finance Transaction",
      "description": "Income and expense tracking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "category", "createdAt"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Monthly spending limits",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "limit": { "type": "number" },
        "month": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "category", "limit", "month"]
    },
    "Investment": {
      "title": "Investment",
      "description": "Asset tracking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "assetName": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["stock", "crypto", "savings"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "assetName", "amount", "type"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "writing/{entryId}": {
      "schema": "WritingEntry",
      "description": "Writing sessions and drafts"
    },
    "learning/{taskId}": {
      "schema": "LearningTask",
      "description": "Educational tasks and progress"
    },
    "moods/{logId}": {
      "schema": "MoodLog",
      "description": "Emotional tracking logs"
    },
    "transactions/{transactionId}": {
      "schema": "FinanceTransaction",
      "description": "User transactions"
    },
    "budgets/{budgetId}": {
      "schema": "Budget",
      "description": "Category budgets"
    },
    "investments/{investmentId}": {
      "schema": "Investment",
      "description": "Asset holdings"
    }
  }
}
